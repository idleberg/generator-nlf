{
	"name": "generator-nlf",
	"version": "0.4.0",
	"description": "Yeoman generator for NSIS Language Files (.nlf)",
	"author": "Jan T. Sott",
	"license": "MIT",
	"keywords": [
		"yeoman-generator",
		"nsis",
		"nlf",
		"nullsoft"
	],
	"type": "module",
	"exports": "./generators/app/index.js",
	"files": [
		"generators"
	],
	"scripts": {
		"lint:e18e": "e18e-cli analyze",
		"lint:code": "biome check",
		"lint": "concurrently --prefix '{name}' -c 'green,blue' 'npm:lint:*'",
		"publish:npm": "np",
		"test": "vitest run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/generator-nlf.git"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@idleberg/yeoman-generator": "^0.3.0",
		"@nsis/language-data": "^0.11.0",
		"@sindresorhus/slugify": "^3.0.0",
		"change-case": "^5.4.4",
		"kleur": "^4.1.5"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@idleberg/configs": "^0.4.2",
		"@types/node": "^24.10.4",
		"@types/yeoman-assert": "^3.1.4",
		"@yeoman/adapter": "^4.0.2",
		"@yeoman/types": "^1.11.1",
		"concurrently": "^9.2.1",
		"np": "^11.2.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6",
		"yeoman-assert": "^3.1.1",
		"yeoman-test": "^11.5.2"
	},
	"packageManager": "pnpm@11.1.3"
}
